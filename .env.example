# Auth.js (NextAuth v5)
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=""
# Required behind a proxy / on Cloudflare Workers (OpenNext).
AUTH_TRUST_HOST="true"

# Mirador backend (mirador-core). When set, login POSTs to ${MIRADOR_API_URL}/api/auth/login.
# Leave empty to use the local dev CEO fallback below until the backend exists.
MIRADOR_API_URL="http://127.0.0.1:3000"

# Dev-only single CEO credentials. Used ONLY when MIRADOR_API_URL is empty.
DEV_CEO_EMAIL="ceo@empresa.com"
DEV_CEO_PASSWORD="mirador-dev"
